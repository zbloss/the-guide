# Copy this file to .env and fill in your values.
# The Guide reads config from config.toml first, then environment variables.
# Environment variables use the GUIDE__ prefix with __ as separator.

# Server
GUIDE__SERVER__HOST=0.0.0.0
GUIDE__SERVER__PORT=8000

# SQLite database path
GUIDE__DATABASE__URL=sqlite://./data/guide.db

# Qdrant vector database
GUIDE__QDRANT__URL=http://localhost:6334
GUIDE__QDRANT__VECTOR_SIZE=768

# Ollama (local LLM)
GUIDE__LLM__OLLAMA_BASE_URL=http://localhost:11434/v1
GUIDE__LLM__DEFAULT_MODEL=llama3.2
GUIDE__LLM__OCR_MODEL=glm4v
GUIDE__LLM__VISION_MODEL=llama3.2-vision
GUIDE__LLM__EMBEDDING_MODEL=nomic-embed-text

# Cloud fallback (optional)
# GUIDE__LLM__CLOUD_FALLBACK=openai
# GUIDE__LLM__CLOUD_API_KEY=sk-...

# Tracing
# RUST_LOG=info,guide_api=debug,guide_llm=debug
