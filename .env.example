# The Guide — environment variable reference (Python version)
# Copy to .env and customise

# Server
GUIDE__HOST=0.0.0.0
GUIDE__PORT=8000

# Database (SQLite path, or :memory: for tests)
GUIDE__DATABASE_URL=data/guide.db

# Ollama (local inference)
GUIDE__OLLAMA_BASE_URL=http://localhost:11434/v1
GUIDE__DEFAULT_MODEL=nanbeige4.1:3b
GUIDE__EMBEDDING_MODEL=nomic-embed-text
GUIDE__OCR_MODEL=glm-ocr
GUIDE__VISION_MODEL=glm4v

# Cloud fallback (optional)
# GUIDE__CLOUD_FALLBACK=openai   # or: gemini
# GUIDE__CLOUD_API_KEY=sk-...

# Upload limit
GUIDE__MAX_UPLOAD_BYTES=52428800  # 50 MB
