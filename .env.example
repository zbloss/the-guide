# The Guide — environment variable reference (Rust version)
# Copy to .env and customise

# Server
GUIDE__HOST=0.0.0.0
GUIDE__PORT=8000

# Database (SQLite path)
GUIDE__DATABASE_URL=sqlite:///app/data/guide.db

# Ollama (local inference) — use host.docker.internal inside Docker
GUIDE__OLLAMA_BASE_URL=http://localhost:11434/v1
GUIDE__DEFAULT_MODEL=qwen3.5:9b
GUIDE__EMBEDDING_MODEL=nomic-embed-text
GUIDE__OCR_MODEL=glm-ocr

# Qdrant
GUIDE__QDRANT_URL=http://localhost:6333
GUIDE__QDRANT_COLLECTION=guide_chunks

# Cloud fallback (optional)
# GUIDE__CLOUD_FALLBACK=openai   # or: gemini
# GUIDE__CLOUD_API_KEY=sk-...

# Upload limit
GUIDE__MAX_UPLOAD_BYTES=524288000  # 500 MB
